<Page x:Class="WarehouseManagement.Pages.InventoryOverviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WarehouseManagement.Pages"
      mc:Ignorable="d"
      d:DesignHeight="700"
      d:DesignWidth="1100"
      Title="InventoryOverviewPage">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource WindowHeaderBorderStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Складские остатки" Style="{StaticResource PageHeaderTextStyle}" Grid.Column="0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="btnManageProducts" Content="Номенклатура" Click="btnAdmin_Click"/>
                    <Button x:Name="btnManageUsers" Content="Пользователи" Click="btnManageUsers_Click"/>
                    <Button x:Name="btnManageShipments" Content="Отгрузки" Click="btnOrders_Click"/>
                    <Button x:Name="btnStockBalances" Content="Остатки" Click="btnCart_Click"/>
                    <Button x:Name="btnExit" Content="Выйти" Click="btnExit_Click"/>
                    <Button x:Name="btnProfile" Content="Профиль" Click="btnProfile_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="12,0,12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock x:Name="tbWelcome"
                               Text="Добро пожаловать"
                               FontSize="22"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="tbRole"
                               Text="Роль:"
                               Margin="0,6,0,0"
                               FontSize="16"/>
                </StackPanel>

                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Width="170" Margin="4,0">
                        <TextBlock Text="Сортировка" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cmbSort" SelectionChanged="cmbSort_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel Width="170" Margin="4,0">
                        <TextBlock Text="Категория" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cmbCategory" SelectionChanged="cmbCategory_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel Width="200" Margin="4,0">
                        <TextBlock Text="Поиск" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtSearch" TextChanged="txtSearch_TextChanged" MaxLength="200"/>
                    </StackPanel>
                </WrapPanel>
            </Grid>
        </Border>

        <ListView x:Name="lvProducts" Grid.Row="2" Margin="12,0,12,12">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding ProductName}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Price, StringFormat=Учетная цена: {0} ₽}" Margin="0,8,0,0" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding QuantityInStock, StringFormat=Остаток: {0}}" Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding Description}" Margin="0,8,0,0" TextWrapping="Wrap" MaxHeight="72" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <Button Content="Списать через отгрузку" Tag="{Binding SourceProduct}" Margin="0,0,0,8" Click="btnAddToCart_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                                <Button Content="Подробнее" Tag="{Binding SourceProduct}" Click="btnDetails_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
