<Page x:Class="WarehouseManagement.Pages.EmployeeProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="EmployeeProfilePage">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Background="{StaticResource ClassicTitleBrush}" LastChildFill="False" Margin="0,0,0,10">
            <TextBlock Text="Профиль пользователя" Style="{StaticResource PageHeaderTextStyle}" Margin="16,12" DockPanel.Dock="Left"/>
            <Button x:Name="btnBack" Content="Назад" Click="btnBack_Click" DockPanel.Dock="Right" Margin="8"/>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="12">
            <Border Style="{StaticResource CardBorderStyle}" Width="560" HorizontalAlignment="Center" Padding="22">
                <StackPanel>
                    <TextBlock Text="Данные аккаунта" FontSize="24" FontWeight="Bold" Margin="0,0,0,14"/>

                    <StackPanel x:Name="spReadOnlyInfo">
                        <TextBlock x:Name="tbFullName" Text="ФИО:" FontSize="20" FontWeight="Bold" TextWrapping="Wrap"/>
                        <TextBlock x:Name="tbLogin" Text="Логин:" Margin="0,10,0,0" FontSize="16"/>
                        <TextBlock x:Name="tbEmail" Text="Email:" Margin="0,10,0,0" FontSize="16" TextWrapping="Wrap"/>
                        <TextBlock x:Name="tbPhone" Text="Телефон:" Margin="0,10,0,0" FontSize="16"/>
                        <TextBlock x:Name="tbRole" Text="Роль:" Margin="0,10,0,0" FontSize="16"/>
                        <TextBlock x:Name="tbCreatedAt" Text="Дата регистрации:" Margin="0,10,0,0" FontSize="16"/>
                    </StackPanel>

                    <StackPanel x:Name="spEditInfo" Visibility="Collapsed">
                        <TextBlock Text="ФИО" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtFullName" MaxLength="200"/>
                        <TextBlock Text="Email" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtEmail" MaxLength="200"/>
                        <TextBlock Text="Телефон" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtPhone" MaxLength="200"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                        <Button x:Name="btnCancelEdit" Content="Отмена" Click="btnCancelEdit_Click" Visibility="Collapsed"/>
                        <Button x:Name="btnEditProfile" Content="Изменить данные" Click="btnEditProfile_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>
