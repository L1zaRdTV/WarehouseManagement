<Page x:Class="WarehouseManagement.Pages.StockBalancesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WarehouseManagement.Pages"
      mc:Ignorable="d"
      d:DesignHeight="700"
      d:DesignWidth="1100"
      Title="StockBalancesPage">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Background="{StaticResource ClassicTitleBrush}" LastChildFill="False" Margin="0,0,0,8">
            <TextBlock Text="Остатки по местам хранения" Style="{StaticResource PageHeaderTextStyle}" Margin="16,12" DockPanel.Dock="Left"/>
            <Button x:Name="btnBack" Content="Назад" Click="btnBack_Click" DockPanel.Dock="Right" Margin="8"/>
        </DockPanel>

        <ListView x:Name="lvStockBalances" Grid.Row="1" Margin="12,0,12,12">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding ProductName}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding PriceAtMoment, StringFormat=Учетная цена: {0} ₽}" Margin="0,5,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="{Binding Quantity, StringFormat=Остаток: {0}}" VerticalAlignment="Center" TextAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding TotalPrice, StringFormat=Стоимость остатка: {0} ₽}" VerticalAlignment="Center" TextAlignment="Center" FontWeight="SemiBold"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border Grid.Row="2" Background="{StaticResource ClassicFaceBrush}" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="tbTotal" Grid.Column="0" Text="Текущие остатки" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0"/>
                <Button x:Name="btnOrder" Grid.Column="1" Content="Перейти к отгрузкам" Width="180" Margin="8,0" Click="btnOpenShipments_Click" Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
