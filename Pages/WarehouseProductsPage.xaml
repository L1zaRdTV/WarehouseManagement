<Page x:Class="WarehouseManagement.Pages.WarehouseProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="WarehouseProductsPage">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Background="{StaticResource ClassicTitleBrush}" LastChildFill="False" Margin="0,0,0,8">
            <TextBlock Style="{StaticResource PageHeaderTextStyle}" Margin="16,10" DockPanel.Dock="Left"><Run Text="Админ-панель "/><Run Text="товаров"/></TextBlock>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="8">
                <Button x:Name="btnUsers" Content="Пользователи" Click="btnUsers_Click"/>
                <Button x:Name="btnBack" Content="Назад" Click="btnBack_Click"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="12,0,12,8">
            <WrapPanel>
                <Button x:Name="btnAdd" Content="Добавить товар" Click="btnAdd_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button x:Name="btnDelete" Content="Удалить" Click="btnDelete_Click"/>
            </WrapPanel>
        </Border>

        <ListView x:Name="lvAdminProducts" Grid.Row="2" Margin="12,0,12,12" MouseDoubleClick="lvAdminProducts_MouseDoubleClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding ProductName}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            <TextBlock Grid.Column="1" Text="{Binding Categories.CategoryName}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding Price, StringFormat={}{0} ₽}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="{Binding QuantityInStock, StringFormat=Остаток: {0}}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
