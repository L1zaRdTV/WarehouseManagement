<Page x:Class="WarehouseManagement.Pages.UserRegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WarehouseManagement.Pages"
      mc:Ignorable="d"
      d:DesignHeight="700"
      d:DesignWidth="1100"
      Title="UserRegistrationPage">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="10">
            <Border Style="{StaticResource CardBorderStyle}"
                    Width="520"
                    MaxWidth="520"
                    HorizontalAlignment="Center"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="Регистрация"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14"/>

                    <TextBlock Text="ФИО:" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtName" MaxLength="200"/>
                    <TextBlock Text="Логин:" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtLogin" MaxLength="200"/>
                    <TextBlock Text="Пароль:" FontWeight="SemiBold"/>
                    <PasswordBox x:Name="txtPassword" MaxLength="200"/>
                    <TextBlock Text="Повторите пароль:" FontWeight="SemiBold"/>
                    <PasswordBox x:Name="txtPasswordRepeat" MaxLength="200"/>
                    <TextBlock Text="Электронная почта:" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtEmail" MaxLength="200"/>
                    <TextBlock Text="Номер телефона:" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtPhone" MaxLength="200"/>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btnBack" Grid.Column="0" Content="Назад" Margin="0,0,8,0" Click="btnBack_Click"/>
                        <Button x:Name="btnRegister" Grid.Column="1" Content="Зарегистрироваться" Margin="8,0,0,0" Click="btnRegister_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>
